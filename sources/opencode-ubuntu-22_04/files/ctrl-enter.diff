diff --git a/packages/opencode/script/build.ts b/packages/opencode/script/build.ts
index f0b3fa828..042993c93 100755
--- a/packages/opencode/script/build.ts
+++ b/packages/opencode/script/build.ts
@@ -14,6 +14,50 @@ process.chdir(dir)

 import pkg from "../package.json"
 import { Script } from "@opencode-ai/script"
+
+// Build web app and embed dist into app-dist.ts
+const appDir = path.resolve(dir, "../../packages/app")
+console.log("Building web app...")
+await $`bun install`.cwd(appDir)
+await $`./node_modules/.bin/vite build`.cwd(appDir)
+
+const appDist = path.join(appDir, "dist")
+const entries: string[] = []
+function walkDir(dir: string, base: string) {
+  for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
+    const full = path.join(dir, entry.name)
+    const rel = path.join(base, entry.name).replace(/\\/g, "/")
+    if (entry.isDirectory()) {
+      walkDir(full, rel)
+    } else {
+      const b64 = Buffer.from(fs.readFileSync(full)).toString("base64")
+      const mime = mimeType(entry.name)
+      entries.push(`  "/${rel}": [${JSON.stringify(b64)}, ${JSON.stringify(mime)}]`)
+    }
+  }
+}
+function mimeType(name: string) {
+  if (name.endsWith(".html")) return "text/html; charset=utf-8"
+  if (name.endsWith(".js")) return "application/javascript"
+  if (name.endsWith(".css")) return "text/css"
+  if (name.endsWith(".json")) return "application/json"
+  if (name.endsWith(".svg")) return "image/svg+xml"
+  if (name.endsWith(".png")) return "image/png"
+  if (name.endsWith(".ico")) return "image/x-icon"
+  if (name.endsWith(".woff2")) return "font/woff2"
+  if (name.endsWith(".woff")) return "font/woff"
+  if (name.endsWith(".webmanifest")) return "application/manifest+json"
+  if (name.endsWith(".wasm")) return "application/wasm"
+  if (name.endsWith(".txt")) return "text/plain"
+  return "application/octet-stream"
+}
+walkDir(appDist, "")
+await Bun.write(
+  path.join(dir, "src/server/app-dist.ts"),
+  `// Auto-generated by build.ts - do not edit\n// Maps path -> [base64-encoded content, mime type]\nexport const files: Record<string, [string, string]> = {\n${entries.join(",\n")},\n}\n`,
+)
+console.log(`Embedded ${entries.length} files from web app dist`)
+
 const modelsUrl = process.env.OPENCODE_MODELS_URL || "https://models.dev"
 // Fetch and generate models.dev snapshot
 const modelsData = process.env.MODELS_DEV_API_JSON
